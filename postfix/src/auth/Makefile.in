SHELL	= /bin/sh
SRCS	= auth.c auth_pg.c auth_maps.c auth_verify.c auth_nets.c \
	auth_cache.c auth_ldap.c ../postapi/auth_key.c
OBJS	= auth.o auth_pg.o auth_maps.o auth_verify.o auth_nets.o \
	auth_cache.o auth_ldap.o ../postapi/auth_key.o
HDRS	= auth.h
TESTSRC	= auth_maps_test.c
DEFS	= -I. -I../postapi -I$(INC_DIR) -D$(SYSTYPE)
CFLAGS	= $(DEBUG) $(OPT) $(DEFS)
TESTPROG= auth_maps_test
PROG	= auth
INC_DIR = ../../include
LIBS	= ../../lib/libxsasl.a \
	../../lib/lib$(LIB_PREFIX)global$(LIB_SUFFIX) \
	../../lib/lib$(LIB_PREFIX)util$(LIB_SUFFIX)

LDAP_EXTRA_LIBS ?= -lldap -llber

.c.o:;	$(CC) $(CFLAGS) -c $*.c

../postapi/%.o: ../postapi/%.c
	$(CC) $(CFLAGS) -c $< -o $@

$(PROG): $(OBJS) $(LIBS)
	$(CC) $(CFLAGS) $(SHLIB_RPATH) -o $@ $(OBJS) $(LIBS) $(SYSLIBS) $(LDAP_EXTRA_LIBS)

$(TESTPROG): $(TESTSRC) auth_maps.o auth_verify.o ../postapi/auth_key.o $(LIBS)
	$(CC) $(CFLAGS) -DTEST $(SHLIB_RPATH) -o $@ $(TESTSRC) auth_maps.o auth_verify.o \
		../postapi/auth_key.o $(LIBS) $(SYSLIBS) $(LDAP_EXTRA_LIBS)

$(OBJS): ../../conf/makedefs.out

Makefile: Makefile.in
	cat ../../conf/makedefs.out $? >$@

test:	$(TESTPROG)

tests:
	./$(TESTPROG)

root_tests:

update: ../../libexec/$(PROG)

../../libexec/$(PROG): $(PROG)
	cp $(PROG) ../../libexec

clean:
	rm -f *.o ../postapi/auth_key.o *core $(PROG) $(TESTPROG) junk

tidy:	clean

depend: $(MAKES)
	(sed '1,/^# do not edit/!d' Makefile.in; \
	set -e; for i in [a-z][a-z0-9]*.c; do \
	    $(CC) -E $(DEFS) $(INCL) $$i | grep -v '[<>]' | sed -n -e '/^# *1 *"\([^"]*\)".*/{' \
	    -e 's//'`echo $$i|sed 's/c$$/o/'`': \1/' \
	    -e 's/o: \.\//o: /' -e p -e '}' ; \
	done | LANG=C sort -u) | grep -v '[.][o][:][ ][/]' >$$$$ && mv $$$$ Makefile.in
	@$(EXPORT) make -f Makefile.in Makefile 1>&2

# do not edit below this line - it is generated by 'make depend'
