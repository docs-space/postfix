#!/bin/sh -e
set -e

clean_binary_symlink() {
    if [ -L "$$1" ]; then
        target=$(readlink "$$1")
        case "$target" in
            /opt/r7-mailserver/mtaserver/usr/bin/*|/opt/r7-mailserver/mtaserver/usr/sbin/*)
                rm -f "$$1"
        ;;
        esac
    fi
}

case "$1" in
    failed-upgrade|abort-install|abort-upgrade|disappear|upgrade)
    ;;
    remove|purge)
        if [ -z "${DPKG_ROOT:-}" ] && [ "$1" = remove ] && [ -d /run/systemd/system ] ; then
	        deb-systemd-invoke stop 'postfix.service' >/dev/null || true
            deb-systemd-invoke disable 'postfix.service' >/dev/null || true
        fi
        #Remove links
        for f in /bin/* /sbin/*; do
            clean_binary_symlink "$f"
        done
        #Remove addition data
        if [ -d /etc/postfix ]; then
            rm -rf /etc/postfix/*
        fi
        if [ -d /opt/r7-mailserver/mtaserver ]; then
            rm -rf /opt/r7-mailserver/mtaserver
        fi
        #Delete service in systemd
        if [ -d /run/systemd/system ]; then
	        if [ -x "/usr/bin/deb-systemd-helper" ]; then
		        deb-systemd-helper purge 'dovecot.service' >/dev/null || true
                systemctl --system daemon-reload >/dev/null || true
	        fi
        fi
    ;;
    *)
        echo "prerm called with unknown argument \`$1'" >&2
        exit 1
esac

exit 0

